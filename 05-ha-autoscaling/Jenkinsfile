pipeline {
  agent any

  environment {
    AWS_REGION     = "us-east-1"
    ECR_REGISTRY   = credentials('ecr-registry-url')
    IMAGE_TAG      = "${env.BUILD_NUMBER}"
    CLUSTER        = "ha-cluster"
    NAMESPACE      = "production"
  }

  options {
    timeout(time: 45, unit: 'MINUTES')
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Test') {
      steps {
        dir('app') {
          sh '''
            python3 -m venv venv
            . venv/bin/activate
            pip install -q -r requirements.txt
            pytest tests/ -v --tb=short 2>/dev/null || echo "No tests"
          '''
        }
      }
    }

    stage('Build & Push') {
      steps {
        sh '''
          aws ecr get-login-password --region ${AWS_REGION} \
            | docker login --username AWS --password-stdin ${ECR_REGISTRY}

          docker build \
            -t ${ECR_REGISTRY}/ha-app:${IMAGE_TAG} \
            -t ${ECR_REGISTRY}/ha-app:latest \
            app/

          docker push ${ECR_REGISTRY}/ha-app:${IMAGE_TAG}
          docker push ${ECR_REGISTRY}/ha-app:latest
        '''
      }
    }

    stage('Deploy') {
      steps {
        sh '''
          aws eks update-kubeconfig \
            --region ${AWS_REGION} \
            --name ${CLUSTER}

          kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

          sed -i "s|IMAGE_PLACEHOLDER|${ECR_REGISTRY}/ha-app:${IMAGE_TAG}|g" \
            k8s/deployment.yaml

          kubectl apply -f k8s/namespace.yaml
          kubectl apply -f k8s/deployment.yaml
          kubectl apply -f k8s/service.yaml
          kubectl apply -f k8s/hpa.yaml

          kubectl rollout status deployment/ha-app \
            -n ${NAMESPACE} \
            --timeout=180s
        '''
      }
    }

    stage('Verify Autoscaling Setup') {
      steps {
        sh '''
          echo "=== HPA Status ==="
          kubectl get hpa ha-app-hpa -n ${NAMESPACE}

          echo ""
          echo "=== PDB Status ==="
          kubectl get pdb ha-app-pdb -n ${NAMESPACE}

          echo ""
          echo "=== Node Count ==="
          kubectl get nodes

          echo ""
          echo "=== Pod Distribution ==="
          kubectl get pods -n ${NAMESPACE} -o wide

          echo ""
          echo "=== Cluster Autoscaler Status ==="
          kubectl get deployment cluster-autoscaler -n kube-system || \
            echo "Cluster Autoscaler not deployed yet"
        '''
      }
    }

    stage('Smoke Test') {
      steps {
        sh '''
          LB=$(kubectl get svc ha-app-svc \
            -n ${NAMESPACE} \
            -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')

          for i in $(seq 1 9); do
            if curl --silent --fail --max-time 10 http://${LB}/health; then
              echo "Health check passed"
              exit 0
            fi
            sleep 10
          done
          exit 1
        '''
      }
    }
  }

  post {
    failure {
      sh 'kubectl rollout undo deployment/ha-app -n ${NAMESPACE} || true'
    }
    always {
      sh 'docker image prune -f || true'
      cleanWs()
    }
  }
}